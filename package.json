{
  "name": "@wular/coder",
  "version": "0.1.10",
  "description": "Delegating coding-agent runtime",
  "type": "module",
  "bin": {
    "coder": "bin/coder.mjs"
  },
  "scripts": {
    "build": "bun build src/cli.ts src/lib/broker.ts --outdir dist --root src --target node --format esm --minify",
    "dev": "bun run build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "version-bump:patch": "node scripts/bump.mjs patch",
    "version-bump:minor": "node scripts/bump.mjs minor",
    "version-bump:major": "node scripts/bump.mjs major",
    "prepublishOnly": "bun run build && bun run typecheck",
    "npm-publish": "npm publish --access public --tag latest --registry=https://registry.npmjs.org --//registry.npmjs.org/:_authToken=\"$NPM_TOKEN\""
  },
  "files": [
    "bin",
    "dist",
    "plugins",
    ".claude-plugin",
    ".agents",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
